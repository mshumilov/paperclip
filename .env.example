# --- Внешняя Postgres (опционально; без DATABASE_URL используется embedded PG в dev) ---
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false

# --- Клиент Paperclip API (агенты, скрипты, Cursor): Authorization: Bearer ---
# Скопируй нужные строки в `.env` и подставь ключ (`.env` в .gitignore).
# Ключ один раз: Board → Agent → API keys, или: pnpm paperclipai agent local-cli …
PAPERCLIP_API_URL=http://localhost:3100
PAPERCLIP_API_KEY=
